# Staging Notarity API base URL (no API key required for staging)
NOTARITY_API_BASE=

# Google Gemini — required for chat engine and live OCR
GEMINI_API_KEY=

# Geoapify — optional address autocomplete in billing/shipping forms
GEOAPIFY_API_KEY=

# Comma-separated OCR model fallback chain (primary first)
OCR_MODELS=

# Set to 1 to serve OCR from fixtures/ocr (zero Gemini calls)
OCR_MOCK=
